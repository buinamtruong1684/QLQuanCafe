using System;
using System.Collections.Generic;
using System.ComponentModel;
using System.Data;
using System.Drawing;
using System.Linq;
using System.Text;
using System.Threading.Tasks;
using System.Windows.Forms;
using QLQuanCafe.Models;
using Microsoft.EntityFrameworkCore;

namespace QLQuanCafe
{
    public partial class frmDashboard : Form
    {
        private QLQuanCafeContext _context;
        private System.Windows.Forms.Timer _refreshTimer;

        public frmDashboard()
        {
            InitializeComponent();
            _context = new QLQuanCafeContext();
        }

        private void frmDashboard_Load(object sender, EventArgs e)
        {
            LoadDashboard();
            UpdateDate();
            
            // Cập nhật dữ liệu mỗi 5 giây
            _refreshTimer = new System.Windows.Forms.Timer();
            _refreshTimer.Interval = 5000;
            _refreshTimer.Tick += (s, ev) => LoadDashboard();
            _refreshTimer.Start();
        }

        private void UpdateDate()
        {
            DateTime now = DateTime.Now;
            string[] dayOfWeek = { "Chủ nhật", "Thứ hai", "Thứ ba", "Thứ tư", "Thứ năm", "Thứ sáu", "Thứ bảy" };
            lblDate.Text = $"{dayOfWeek[(int)now.DayOfWeek]}, {now.Day} tháng {now.Month}, {now.Year}";
        }

        private void LoadDashboard()
        {
            try
            {
                LoadTongTienHom();
                LoadSoBanDangDung();
                LoadSoHoaDonHom();
                LoadRecentInvoices();
                LoadTopSellingItems();
            }
            catch (Exception ex)
            {
                MessageBox.Show("Lỗi: " + ex.Message);
            }
        }

        private void LoadTongTienHom()
        {
            try
            {
                var today = DateTime.Now.Date;
                
                var tongTien = _context.HoaDons
                    .Where(h => h.NgayLap.HasValue && h.NgayLap.Value.Date == today)
                    .SelectMany(h => h.ChiTietHoaDons)
                    .Sum(c => (c.SoLuong ?? 0) * (c.DonGia ?? 0));

                lblTongTienHom.Text = tongTien.ToString("N0") + " đ";
                
                // Tính trung bình
                var soHoaDon = _context.HoaDons
                    .Where(h => h.NgayLap.HasValue && h.NgayLap.Value.Date == today)
                    .Count();
                
                if (soHoaDon > 0)
                {
                    var trungBinh = tongTien / soHoaDon;
                    lblSoHoaDonHomSub.Text = $"Trung bình {trungBinh:N0} đ / HĐ";
                }
            }
            catch (Exception ex)
            {
                lblTongTienHom.Text = "Lỗi";
                MessageBox.Show("Lỗi tính tổng tiền: " + ex.Message);
            }
        }

        private void LoadSoBanDangDung()
        {
            try
            {
                var soBanDangDung = _context.Bans
                    .Where(b => b.TrangThai == "Có khách")
                    .Count();

                var tongSoBan = _context.Bans.Count();

                lblSoBanDangDung.Text = $"{soBanDangDung} / {tongSoBan}";
                lblSoBanDangDungSub.Text = $"Tổng {tongSoBan} bàn";
            }
            catch (Exception ex)
            {
                lblSoBanDangDung.Text = "Lỗi";
                MessageBox.Show("Lỗi tính số bàn: " + ex.Message);
            }
        }

        private void LoadSoHoaDonHom()
        {
            try
            {
                var today = DateTime.Now.Date;
                
                var soHoaDon = _context.HoaDons
                    .Where(h => h.NgayLap.HasValue && h.NgayLap.Value.Date == today)
                    .Count();

                lblSoHoaDonHom.Text = soHoaDon.ToString();
            }
            catch (Exception ex)
            {
                lblSoHoaDonHom.Text = "Lỗi";
                MessageBox.Show("Lỗi tính số hóa đơn: " + ex.Message);
            }
        }

        private void LoadRecentInvoices()
        {
            try
            {
                var today = DateTime.Now.Date;
                
                var recentInvoices = _context.HoaDons
                    .Where(h => h.NgayLap.HasValue && h.NgayLap.Value.Date == today)
                    .OrderByDescending(h => h.NgayLap)
                    .Take(5)
                    .Select(h => new
                    {
                        Bàn = h.MaBanNavigation != null ? h.MaBanNavigation.TenBan : "Mang đi",
                        Thời_gian = h.NgayLap.Value.ToString("HH:mm"),
                        Món = string.Join(", ", h.ChiTietHoaDons.Select(c => c.MaSpNavigation.TenSp + " x" + c.SoLuong)),
                        Giá = h.ChiTietHoaDons.Sum(c => (c.SoLuong ?? 0) * (c.DonGia ?? 0)).ToString("N0") + " đ"
                    })
                    .ToList();

                dgvRecentInvoices.DataSource = recentInvoices;
                dgvRecentInvoices.Columns[0].Width = 80;
                dgvRecentInvoices.Columns[1].Width = 70;
                dgvRecentInvoices.Columns[2].Width = 150;
            }
            catch (Exception ex)
            {
                MessageBox.Show("Lỗi load hoá đơn gần đây: " + ex.Message);
            }
        }

        private void LoadTopSellingItems()
        {
            try
            {
                var today = DateTime.Now.Date;
                
                var topItems = _context.ChiTietHoaDons
                    .Where(c => c.MaHdNavigation.NgayLap.HasValue && c.MaHdNavigation.NgayLap.Value.Date == today)
                    .GroupBy(c => c.MaSpNavigation.TenSp)
                    .Select(g => new
                    {
                        Tên_sản_phẩm = g.Key,
                        Số_lượng = g.Sum(c => c.SoLuong ?? 0)
                    })
                    .OrderByDescending(x => x.Số_lượng)
                    .Take(10)
                    .ToList();

                dgvTopSellingItems.DataSource = topItems;
                dgvTopSellingItems.Columns[0].Width = 250;
                dgvTopSellingItems.Columns[1].Width = 80;
            }
            catch (Exception ex)
            {
                MessageBox.Show("Lỗi load món bán chay: " + ex.Message);
            }
        }

        private void frmDashboard_FormClosing(object sender, FormClosingEventArgs e)
        {
            _refreshTimer?.Stop();
            _refreshTimer?.Dispose();
            _context?.Dispose();
        }
    }
}
